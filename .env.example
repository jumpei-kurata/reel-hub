# Render上のアプリURL（例: https://reel-hub.onrender.com）
APP_BASE_URL=https://your-app.onrender.com

# Facebook Page ID（ページのURL末尾の数字）
FACEBOOK_PAGE_ID=61586039124630

# Facebook Page Access Token
# 取得方法: developers.facebook.com → グラフAPIエクスプローラー → ページアクセストークン
FACEBOOK_PAGE_ACCESS_TOKEN=

# --- 自動メンテ(起床時のトークン自動更新＋コメント処理)に必要 ---
# Meta App ID / Secret（トークン更新 fb_exchange_token 用）
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
# Instagram Business Account ID（コメント自動処理用）
INSTAGRAM_BUSINESS_ACCOUNT_ID=
# Render REST API（更新後トークンを env に書き戻すため）
RENDER_API_KEY=
RENDER_SERVICE_ID=
# /api/refresh-token 認可用のランダム文字列（openssl rand -hex 32）
REFRESH_SECRET=
# Upstash Redis REST（コメントいいね済みIDの永続dedup用・upstash.com 無料枠で作成）
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# TikTok Developer App（developers.tiktok.com で作成）
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# TikTok アクセストークン（/auth/tiktok にアクセスして取得）
TIKTOK_ACCESS_TOKEN=
TIKTOK_REFRESH_TOKEN=
